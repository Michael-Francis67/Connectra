{
  "name": "connectra_gateway",
  "version": "1.0.0",
  "description": "Connectra is modern professional and production ready chat app, this is the api gateway service.",
  "keywords": [
    "[\"Chat\"",
    "\"Messaging\"",
    "\"Api\"",
    "\"Calls\"]"
  ],
  "repository": {
    "type": "git",
    "url": "connectra"
  },
  "license": "MIT",
  "author": "Michael",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"./**/*.ts\"",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "start": "node src/index.ts",
    "dev": "nodemon",
    "build": "rimraf dist && babel src --out-dir dist"
  },
  "dependencies": {
    "@arcjet/inspect": "^1.3.1",
    "@arcjet/node": "^1.3.1",
    "@clerk/express": "^2.0.8",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "babel-jest": "^30.3.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "module-alias": "^2.3.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "_moduleAliases": {
    "@": "src"
  }
}
